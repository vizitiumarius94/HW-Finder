# Copy to .env (do not commit secrets)
PORT=8000
GITHUB_APP_ID=4266851
GITHUB_INSTALLATION_ID=145723468
GITHUB_REPO=vizitiumarius94/HW-Finder
# GitHub App private key must be PEM text including BEGIN/END lines.
# Keep it as a single value (use quotes) in your real .env.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Comma-separated list of paths allowed to be modified
# (we will only allow data.json)
ALLOWED_PATHS=data.json

